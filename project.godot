; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Diploma"
run/main_scene="res://scenes/room1.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/stretch_mode=4
boot_splash/image="uid://sjgjf2sro3tb"
config/icon="res://icon.svg"
run/stretch/scale=1.0
run/size/viewport_height=1080
run/size/viewport_width=1920

[audio]

buses/default_bus_layout="uid://wb6ofv304tjx"

[autoload]

tree_wind_size="*uid://bhadppjyp7q5n"

[display]

window/stretch/mode="viewport"
window/stretch/scale=0.75
window/enabled=false

[editor_plugins]

enabled=PackedStringArray("res://addons/SunshineClouds2/plugin.cfg", "res://addons/asset_placer/plugin.cfg", "res://addons/godot_gif/plugin.cfg", "res://addons/godot_material_footsteps/plugin.cfg", "res://addons/proton_scatter/plugin.cfg", "res://addons/raytraced_audio/plugin.cfg", "res://addons/terrain_3d/plugin.cfg")

[file_customization]

folder_colors={
"res://3D/": "orange",
"res://Audio/": "red",
"res://addons/": "gray",
"res://codes/": "gray",
"res://demo/": "gray",
"res://example/": "gray",
"res://old_3D/": "orange",
"res://old_textures/": "gray",
"res://scenes/": "blue",
"res://textures/": "green"
}

